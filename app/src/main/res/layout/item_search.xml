<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            android:layout_marginEnd="12dp">

            <ImageView
                android:id="@+id/ivIconSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#F5F5F5"/>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNameSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quán Cơm Bà Hai"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvCategorySearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhà hàng bình dân"
                android:textSize="12sp"
                android:textColor="#FF7043"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvAddressSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="123 Lý Bôn, P.1, TP.Cà Mau"
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvRatingSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.5"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="·"
                    android:textColor="#999999"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvViewsSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120 lượt xem"
                    android:textSize="12sp"
                    android:textColor="#999999"/>
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivFavoriteSearch"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_favorite_24"
            android:padding="4dp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
